{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local: Run API",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "app:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pi: Sync project",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\pi_sync.ps1"
      ],
      "options": {
        "env": {
          "TELETOOL_PI_HOST": "${config:teletool.piHost}",
          "TELETOOL_PI_USER": "${config:teletool.piUser}",
          "TELETOOL_PI_PATH": "${config:teletool.piPath}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Pi: Sync project including config",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\pi_sync.ps1",
        "-IncludeConfig"
      ],
      "options": {
        "env": {
          "TELETOOL_PI_HOST": "${config:teletool.piHost}",
          "TELETOOL_PI_USER": "${config:teletool.piUser}",
          "TELETOOL_PI_PATH": "${config:teletool.piPath}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Pi: Setup dependencies/service",
      "type": "shell",
      "command": "ssh",
      "args": [
        "${config:teletool.piUser}@${config:teletool.piHost}",
        "cd ${config:teletool.piPath} && bash scripts/pi_setup.sh"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pi: Restart service",
      "type": "shell",
      "command": "ssh",
      "args": [
        "${config:teletool.piUser}@${config:teletool.piHost}",
        "sudo systemctl restart tvh_ndi_bridge.service && systemctl --no-pager --full status tvh_ndi_bridge.service"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pi: Tail service logs",
      "type": "shell",
      "command": "ssh",
      "args": [
        "${config:teletool.piUser}@${config:teletool.piHost}",
        "journalctl -u tvh_ndi_bridge.service -f"
      ],
      "problemMatcher": []
    }
  ]
}
