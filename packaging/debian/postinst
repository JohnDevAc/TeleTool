#!/bin/sh
set -e

. /usr/lib/teletool/bin/terminal-ui
defer_completion="${TELETOOL_DEFER_COMPLETION:-0}"
if [ "$defer_completion" != "1" ]; then
  tt_ui_init
  trap tt_ui_reset EXIT
  tt_ui_progress 85 "Finalising TeleTool services" "Starting the Web UI and Tvheadend"
fi

if ! getent group teletool >/dev/null 2>&1; then
  addgroup --system teletool >/dev/null
fi
if ! getent passwd teletool >/dev/null 2>&1; then
  adduser --system --home /var/lib/teletool --shell /usr/sbin/nologin \
    --ingroup teletool --no-create-home teletool >/dev/null
fi

install -d -o teletool -g teletool -m 0750 /var/lib/teletool
if [ ! -f /var/lib/teletool/config.json ]; then
  install -o teletool -g teletool -m 0640 \
    /usr/lib/teletool/config.example.json /var/lib/teletool/config.json
else
  chown teletool:teletool /var/lib/teletool/config.json
fi

for group in audio video; do
  if getent group "$group" >/dev/null 2>&1; then
    usermod -aG "$group" teletool
  fi
done

if command -v visudo >/dev/null 2>&1; then
  visudo -cf /etc/sudoers.d/teletool >/dev/null
fi

ldconfig
systemctl daemon-reload 2>/dev/null || true
systemctl enable --now avahi-daemon.service 2>/dev/null || true
systemctl enable --now NetworkManager.service 2>/dev/null || true

if [ -x /usr/lib/teletool/bin/configure-tvheadend ]; then
  /usr/lib/teletool/bin/configure-tvheadend || \
    echo "WARNING: Tvheadend automatic configuration did not complete." >&2
fi

# Stop checkout-based legacy services so only the package-owned service binds
# the Web UI port. The legacy application files and config are left untouched.
systemctl disable --now tvh_ndi_bridge.service 2>/dev/null || true
systemctl disable --now tvh-ndi-bridge.service 2>/dev/null || true
systemctl enable teletool.service 2>/dev/null || true
systemctl restart teletool.service 2>/dev/null || true

if [ "$defer_completion" = "1" ]; then
  exit 0
fi

ip="$(hostname -I 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i ~ /^[0-9]+\./ && $i !~ /^127\./) {print $i; exit}}')"
if [ -z "$ip" ]; then
  ip="$(hostname -s 2>/dev/null || printf teletool).local"
fi

tt_ui_completion_header
tt_ui_web_link "http://$ip:8000/"
if ! systemctl is-active --quiet teletool.service 2>/dev/null; then
  tt_ui_status ERROR "TeleTool service did not start; run systemctl status teletool"
fi
if ! systemctl is-active --quiet tvheadend.service 2>/dev/null; then
  tt_ui_status WARN "Tvheadend service is not running"
fi
if ! gst-inspect-1.0 ndisink >/dev/null 2>&1 || \
   ! gst-inspect-1.0 ndisinkcombiner >/dev/null 2>&1; then
  tt_ui_status ERROR "GStreamer NDI plugin verification failed"
fi
if ! gst-inspect-1.0 alsasink >/dev/null 2>&1; then
  tt_ui_status WARN "GStreamer ALSA audio output was not detected"
fi

runtime_ready=0
if ldconfig -p 2>/dev/null | grep -q 'libndi\.so\.6' && \
   [ -f /var/lib/teletool/ndi-runtime-verified ]; then
  runtime_ready=1
fi

if [ "$runtime_ready" -ne 1 ]; then
  printf '\n  %sNDI SDK REQUIRED%s\n' "$TT_UI_YELLOW" "$TT_UI_RESET"
  printf '  Open the address above and upload the ARM64 libndi.so.6 file.\n'
  printf '  SDK: https://ndi.video/for-developers/ndi-sdk/\n'
fi
printf '\n'

exit 0
