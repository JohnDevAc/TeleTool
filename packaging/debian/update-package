#!/bin/sh
set -eu

STATUS_DIR="/var/lib/teletool"
STATUS_FILE="$STATUS_DIR/update-status.json"
LOG_FILE="/var/log/teletool-web-update.log"
SOURCE_FILE="/etc/apt/sources.list.d/teletool.sources"
KEYRING="/usr/share/keyrings/teletool-archive-keyring.gpg"
channel="${1:-}"
started_at="$(date +%s)"

case "$channel" in
  main)
    channel_label="Main"
    repository_url="https://johndevac.github.io/TeleTool/apt-repo"
    suite="stable"
    ;;
  dev)
    channel_label="Dev"
    repository_url="https://raw.githubusercontent.com/JohnDevAc/TeleTool/dev/apt-repo-dev"
    suite="dev"
    ;;
  *)
    printf 'Usage: %s main|dev\n' "$0" >&2
    exit 2
    ;;
esac

write_status() {
  running="$1"
  done="$2"
  percent="$3"
  step="$4"
  error_json="$5"
  finished_at="$6"
  restart_required="$7"
  tmp="$(mktemp "$STATUS_DIR/.update-status.XXXXXX")"
  printf '{\n  "running": %s,\n  "done": %s,\n  "percent": %s,\n  "step": "%s",\n  "error": %s,\n  "started_at": %s,\n  "finished_at": %s,\n  "branch": "%s",\n  "package_managed": true,\n  "restart_required": %s,\n  "log": "%s"\n}\n' \
    "$running" "$done" "$percent" "$step" "$error_json" \
    "$started_at" "$finished_at" "$channel" "$restart_required" "$LOG_FILE" >"$tmp"
  install -o teletool -g teletool -m 0640 "$tmp" "$STATUS_FILE"
  rm -f "$tmp"
}

update_failed() {
  rc="$?"
  trap - EXIT
  write_status false true 100 "Update failed. See the update log." \
    '"Package update failed"' "$(date +%s)" false
  exit "$rc"
}

install -d -o teletool -g teletool -m 0750 "$STATUS_DIR"
install -d -m 0755 /var/log
: >"$LOG_FILE"
chmod 0644 "$LOG_FILE"
trap update_failed EXIT

write_status true false 5 "Selecting the signed $channel_label channel" null null false
exec >>"$LOG_FILE" 2>&1

cat >"$SOURCE_FILE" <<EOF
Types: deb
URIs: $repository_url
Suites: $suite
Components: main
Architectures: arm64
Signed-By: $KEYRING
EOF

write_status true false 20 "Checking the signed $channel_label repository" null null false
apt-get -qq -o Acquire::Retries=3 -o DPkg::Lock::Timeout=300 update
write_status true false 45 "Resolving the $channel_label package version" null null false

before="$(dpkg-query -W -f='${Version}' teletool 2>/dev/null || true)"
before_inferno="$(dpkg-query -W -f='${Version}' teletool-inferno 2>/dev/null || true)"
target_version="$(apt-cache madison teletool | awk 'NR == 1 {print $3}')"
case "$target_version" in
  ''|*[!0-9A-Za-z.+:~_-]*)
    printf 'No valid TeleTool package was found in the %s repository.\n' "$channel_label" >&2
    exit 1
    ;;
esac
target_inferno_version="$(apt-cache madison teletool-inferno | awk 'NR == 1 {print $3}')"

write_status true false 65 "Installing TeleTool $target_version from $channel_label" null null false
set -- "teletool=$target_version"
if [ "$target_inferno_version" = "$target_version" ]; then
  set -- "$@" "teletool-inferno=$target_version"
else
  printf 'No matching teletool-inferno package was found for %s in the %s repository.\n' \
    "$target_version" "$channel_label"
fi
DEBIAN_FRONTEND=noninteractive apt-get -qq \
  -o Acquire::Retries=3 -o DPkg::Lock::Timeout=300 -o Dpkg::Use-Pty=0 \
  install --allow-downgrades -y "$@"
after="$(dpkg-query -W -f='${Version}' teletool 2>/dev/null || true)"
after_inferno="$(dpkg-query -W -f='${Version}' teletool-inferno 2>/dev/null || true)"

trap - EXIT
if [ -n "$before" ] && [ "$before" = "$after" ] && [ "$before_inferno" = "$after_inferno" ]; then
  write_status false true 100 "TeleTool $channel_label is already up to date." null "$(date +%s)" false
else
  write_status false true 100 "Switched to TeleTool $channel_label $after." null "$(date +%s)" true
fi

exit 0
